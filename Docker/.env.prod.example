# gsmnode — production stack config.
# Copy to .env and fill in, then:
#   docker compose -f docker-compose.prod.yml pull
#   docker compose -f docker-compose.prod.yml up -d

# --- Registry images ---------------------------------------------------------
# REQUIRED — there is no public registry for these yet, so point them at your
# own. Build and push them from this tree first:
#
#   docker compose build                          # uses docker-compose.yml
#   docker tag gsmnode-api-server <registry>/gsmnode-api-server:latest
#   docker push <registry>/gsmnode-api-server:latest      # and the other two
#
PB_IMAGE=registry.example.com/gsmnode-pocketbase:latest
API_IMAGE=registry.example.com/gsmnode-api-server:latest
WEB_IMAGE=registry.example.com/gsmnode-web-app:latest

# --- PocketBase superuser ----------------------------------------------------
# Created/updated on the PocketBase container's first boot. The API Server uses
# these same credentials to manage the database. REQUIRED.
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=change-me-long-password

# --- gsmnode super-admin (app login) ----------------------------------------
# The first application user, created by the API Server on boot with role
# "superadmin" if no user with this email exists yet. This is the account you log
# in to the web app with — distinct from the PocketBase superuser above. Leave
# blank to skip and create the first user by hand.
GSMNODE_SUPERADMIN_EMAIL=owner@example.com
GSMNODE_SUPERADMIN_PASSWORD=change-me-long-password
GSMNODE_SUPERADMIN_NAME=Administrator
# Set to false to skip schema creation/reconcile once the database is set up.
PB_BOOTSTRAP=true

# --- API Server --------------------------------------------------------------
# Secret used to sign client JWTs. REQUIRED — use a long random string.
JWT_SECRET=change-me-to-a-long-random-string
# Access token lifetime (Go duration: 30m, 24h, 168h ...).
JWT_ACCESS_TTL=24h
# How long a message/call may stay unprocessed before it's marked Failed.
MESSAGE_TTL=5m
# Allowed CORS origin(s) for the web app (match your public URL / WEB_PORT).
CORS_ALLOW_ORIGINS=http://localhost:8090

# --- Ports -------------------------------------------------------------------
# WEB_PORT is the public front door (bound on all interfaces).
WEB_PORT=8090
# PocketBase admin UI and the API panel are bound to localhost only by default.
# Set PB_BIND / API_BIND to 0.0.0.0 to expose them on the network.
PB_PORT=8070
PB_BIND=127.0.0.1
API_PORT=8080
API_BIND=127.0.0.1

# --- Storage -----------------------------------------------------------------
# Default is a Docker-managed named volume ("pb_data"). To store the database on
# a host path instead, set PB_DATA to an absolute path, e.g.:
#   PB_DATA=/srv/gsmnode/pb_data
PB_DATA=pb_data
# The API Server's own state: plugin enable-state and config (plugins.json) plus
# the settings the panel persists. Separate from the database, and worth backing
# up with it — plugin config holds credentials such as IMAP/SMTP logins.
#
# Unlike PocketBase, the API Server container runs as an unprivileged user, and a
# named volume inherits that ownership while a host path keeps the host's. If you
# point this at a host path, chown it to the container's uid first, or the server
# will start fine and then fail every attempt to save plugin config:
#   docker compose -f docker-compose.prod.yml run --rm --user root api-server \
#     chown -R app:app /data
API_DATA=api_data
