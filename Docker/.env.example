# Copy to .env and fill in. Used by the root docker-compose.yml.

# --- PocketBase superuser (also used by the API Server to authenticate) ------
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=change-me-long-password

# --- gsmnode super-admin (app login) ----------------------------------------
# The first application user, created by the API Server on boot with role
# "superadmin" if no user with this email exists yet. This is the account you log
# in to the web app with — distinct from the PocketBase superuser above. Leave
# blank to skip and create the first user by hand.
GSMNODE_SUPERADMIN_EMAIL=owner@example.com
GSMNODE_SUPERADMIN_PASSWORD=change-me-long-password
GSMNODE_SUPERADMIN_NAME=Administrator
# Set to false to skip schema creation/reconcile once the database is set up.
PB_BOOTSTRAP=true

# --- API Server -------------------------------------------------------------
# How long a message/call may stay unprocessed before it's marked Failed.
MESSAGE_TTL=5m
# Allowed CORS origin(s) for the web app (match WEB_PORT / your public URL).
# Native mobile apps are not subject to CORS.
CORS_ALLOW_ORIGINS=http://localhost:8090

# --- Host port mappings (optional; defaults shown) --------------------------
PB_PORT=8070
API_PORT=8080
WEB_PORT=8090

# --- Web App build -----------------------------------------------------------
# Leave empty so the browser uses same-origin /api (proxied by the BFF).
VITE_API_BASE=
